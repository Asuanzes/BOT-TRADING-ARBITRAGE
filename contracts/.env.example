# Copy to .env and fill in. .env is gitignored.

# RPC for Arbitrum Sepolia. Public endpoint works for reads; for deploys/scripts
# under load, use Alchemy/Infura/QuickNode.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployer key (Arbitrum Sepolia, no real funds). Never reuse a mainnet key.
PRIVATE_KEY=0x

# Optional: Arbiscan API key for `forge verify-contract`.
ARBISCAN_API_KEY=
